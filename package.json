{
  "name": "pi-stuff",
  "version": "1.0.0",
  "description": "My pi extensions, skills and more",
  "keywords": ["pi-package"],
  "pi": {
    "extensions": [
      "./extensions",
      "./node_modules/agent-stuff/pi-extensions/todos.ts",
      "./node_modules/agent-stuff/pi-extensions/review.ts",
      "./node_modules/agent-stuff/pi-extensions/session-breakdown.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/agent-stuff/skills/github",
      "./node_modules/agent-stuff/skills/pi-share"
    ],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  },
  "dependencies": {
    "agent-stuff": "github:mitsuhiko/agent-stuff"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
